{
    "name": "baris/magento2-store-bodyclass",
    "description": "Magento 2 module that automatically adds store code and normalized store name as CSS classes to the body tag",
    "version": "1.0.0",
    "type": "magento2-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Baris",
            "email": "mageyazilim@outlook.com"
        }
    ],
    "require": {
        "magento/framework": "^103.0.0|^104.0.0",
        "php": "^8.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "files": ["Baris/StoreBodyClass/registration.php"],
        "psr-4": {
            "Baris\\StoreBodyClass\\": "Baris/StoreBodyClass/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://repo.magento.com/"
        }
    ],
    "keywords": [
        "magento2",
        "module",
        "css",
        "body-class",
        "store-code"
    ],
    "support": {
        "issues": "https://github.com/barist26/magento2_bodyclass/issues",
        "source": "https://github.com/barist26/magento2_bodyclass"
    }
}
